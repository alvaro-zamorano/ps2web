 CPs2VmJs* g_virtualMachine = nullptr;
 CGSHandler::NewFrameEvent::Connection g_gsNewFrameConnection;
@@ -152,6 +154,17 @@ double getJitMs() { return g_ps2webJitNs.load() / 1e6; }
 int getJitBlocks() { return static_cast<int>(g_ps2webJitBlocks.load()); }
 double getDispatches() { return static_cast<double>(g_ps2webDispatches.load()); }
 int getChainMapEntries() { std::lock_guard<std::mutex> _l(g_ps2webChainMapMtx); return static_cast<int>(g_ps2webChainMap.size()); }
+// PS2WEB(F3): deterministic emulation-state hash (EE base RAM, strided). Replaces the unreliable
+// canvas frameHash as the JIT correctness gate. Read-only; any CPU divergence changes it.
+double getStateHash() {
+	if(!g_virtualMachine) return 0;
+	auto& ee = g_virtualMachine->m_ee;
+	if(!ee || !ee->m_ram) return 0;
+	const uint8* ram = ee->m_ram;
+	uint32 h = 2166136261u;
+	for(uint32 i = 0; i < PS2::EE_BASE_RAM_SIZE; i += 16) { h ^= ram[i]; h *= 16777619u; }
+	return static_cast<double>(h);
+}
 
