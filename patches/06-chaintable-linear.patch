index 30700c1..3a0bab6 100644
--- a/Source/BasicBlock.cpp
+++ b/Source/BasicBlock.cpp
@@ -15,6 +15,23 @@ std::atomic<uint64_t> g_ps2webDispatches{0};
 #include <mutex>
 std::unordered_map<uint32, uint32> g_ps2webChainMap;
 std::mutex g_ps2webChainMapMtx;
+// PS2WEB(F3 W2.2b.1): flat PC->tableIndex open-addressed hash in LINEAR MEMORY (indexable by hand-emitted wasm).
+static const uint32 PS2WEB_CHAIN_BITS = 18;
+static const uint32 PS2WEB_CHAIN_SIZE = 1u << PS2WEB_CHAIN_BITS;
+static const uint32 PS2WEB_CHAIN_MASK = PS2WEB_CHAIN_SIZE - 1;
+uint32 g_ps2webChainKey[PS2WEB_CHAIN_SIZE] = {0}; // stored key = pc+1 (0 = empty slot)
+uint32 g_ps2webChainVal[PS2WEB_CHAIN_SIZE] = {0};
+static inline uint32 ps2webChainHash(uint32 pc) { return (pc * 2654435761u) >> (32 - PS2WEB_CHAIN_BITS); }
+void ps2webChainInsert(uint32 pc, uint32 tableIndex) {
+	uint32 k = pc + 1, h = ps2webChainHash(pc);
+	while(g_ps2webChainKey[h] != 0 && g_ps2webChainKey[h] != k) h = (h + 1) & PS2WEB_CHAIN_MASK;
+	g_ps2webChainKey[h] = k; g_ps2webChainVal[h] = tableIndex;
+}
+uint32 ps2webChainLookup(uint32 pc) {
+	uint32 k = pc + 1, h = ps2webChainHash(pc);
+	while(g_ps2webChainKey[h] != 0) { if(g_ps2webChainKey[h] == k) return g_ps2webChainVal[h]; h = (h + 1) & PS2WEB_CHAIN_MASK; }
+	return 0;
+}
 
