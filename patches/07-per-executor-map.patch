+	static const uint32 PS2WEB_EXECMAP_BITS = 18;
+	static const uint32 PS2WEB_EXECMAP_SIZE = 1u << PS2WEB_EXECMAP_BITS;
+	static const uint32 PS2WEB_EXECMAP_MASK = PS2WEB_EXECMAP_SIZE - 1;
+	static uint32 ps2webExecHash(uint32 pc) { return (pc * 2654435761u) >> (32 - PS2WEB_EXECMAP_BITS); }
+	void ps2webExecEnsure() { if(m_ps2webKey.empty()) { m_ps2webKey.assign(PS2WEB_EXECMAP_SIZE, 0); m_ps2webVal.assign(PS2WEB_EXECMAP_SIZE, 0); } }
+	void ps2webExecClear() { m_ps2webKey.clear(); m_ps2webVal.clear(); }
+	uint32 ps2webExecLookup(uint32 pc) {
+		if(m_ps2webKey.empty()) return 0;
+		uint32 k = pc + 1, h = ps2webExecHash(pc);
+		while(m_ps2webKey[h] != 0) { if(m_ps2webKey[h] == k) return m_ps2webVal[h]; h = (h + 1) & PS2WEB_EXECMAP_MASK; }
+		return 0;
+	}
+	void ps2webExecInsert(uint32 pc, uint32 idx) {
+		if(pc == MIPS_INVALID_PC) return;
+		ps2webExecEnsure();
+		uint32 k = pc + 1, h = ps2webExecHash(pc);
+		while(m_ps2webKey[h] != 0 && m_ps2webKey[h] != k) h = (h + 1) & PS2WEB_EXECMAP_MASK;
+		m_ps2webKey[h] = k; m_ps2webVal[h] = idx;
+		if(ps2webExecLookup(pc) != idx) g_ps2webExecMismatches.fetch_add(1, std::memory_order_relaxed);
+	}
+	void ps2webExecErase(uint32 pc) {
+		if(m_ps2webKey.empty()) return;
+		uint32 k = pc + 1, h = ps2webExecHash(pc);
+		while(m_ps2webKey[h] != 0) { if(m_ps2webKey[h] == k) { m_ps2webVal[h] = 0; return; } h = (h + 1) & PS2WEB_EXECMAP_MASK; }
+	}
+#endif
