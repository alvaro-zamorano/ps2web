 extern std::atomic<uint64_t> g_ps2webDispatches; // PS2WEB(F3): block dispatch counter
 
@@ -72,6 +73,24 @@ public:
 		while(m_context.m_State.nHasException == 0)
 		{
 			uint32 address = m_context.m_State.nPC & m_addressMask;
+#ifdef __EMSCRIPTEN__
+			// PS2WEB(F3 W2.2b.2b): fast-path — dispatch via the per-executor flat map, skipping
+			// FindBlockAt + the virtual CBasicBlock::Execute. Periodic audit vs FindBlockAt catches
+			// stale entries (block recycling/invalidation). cube golden gates EE correctness.
+			uint32 ps2webIdx = ps2webExecLookup(address);
+			if(ps2webIdx != 0)
+			{
+				if((g_ps2webDispatches.load(std::memory_order_relaxed) & 0x3FF) == 0)
+				{
+					auto auditBlock = m_blockLookup.FindBlockAt(address);
+					if(!auditBlock->IsEmpty() && auditBlock->GetWasmTableIndex() != ps2webIdx)
+						g_ps2webFastMismatches.fetch_add(1, std::memory_order_relaxed);
+				}
+				reinterpret_cast<void(*)(void*)>(static_cast<uintptr_t>(ps2webIdx))(&m_context);
+				g_ps2webDispatches.fetch_add(1, std::memory_order_relaxed);
+				continue;
+			}
+#endif
 			auto block = m_blockLookup.FindBlockAt(address);
 			block->Execute();
 			g_ps2webDispatches.fetch_add(1, std::memory_order_relaxed); // PS2WEB(F3)
