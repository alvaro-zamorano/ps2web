+void CBasicBlock::Ps2webClearModuleBytes()
+{
+	m_ps2webModuleBytes.clear();
+	m_ps2webModuleBytes.shrink_to_fit();
+}
+
+// PS2WEB(JIT-04): point this block at a function inside a batch module. Assigning m_function
+// destroys the old CMemoryFunction, which removes its indirect-table entry and drops its
+// reference to the solo module — freeing that module's code-space once nothing else holds it.
+// Safe to swap the entry point because the wasm build has NO block linking (LinkBlock/UnlinkBlock
+// are compiled out under __EMSCRIPTEN__): a block's identity is just its table index.
+void CBasicBlock::Ps2webRepoint(CMemoryFunction&& function)
+{
+	m_function = std::move(function);
+	Ps2webClearModuleBytes();
+}
+
+// PS2WEB(JIT-04) BISECT: move the current function OUT without destroying it, so the caller can
+// keep the solo module (and its table entry) alive. Leaves m_function empty, so the subsequent
+// Ps2webRepoint's Reset() is a no-op and nothing is removed from the indirect table.
+CMemoryFunction CBasicBlock::Ps2webTakeFunction()
+{
+	return std::move(m_function);
+}
