+// PS2WEB(JIT-04): encode local decls + code into a single body blob at Add time, so that
+// bodies produced by the codegen and bodies extracted from previously-emitted modules are
+// handled uniformly by WriteModule.
+CWasmModuleBuilder::FunctionCode CWasmModuleBuilder::EncodeFunctionBody(const FUNCTION& function)
+{
+	assert(function.localI32Count < 0x80);
+	assert(function.localI64Count < 0x80);
+	assert(function.localF32Count < 0x80);
+	assert(function.localV128Count < 0x80);
+
+	uint32 localDeclCount = 0;
+	if(function.localI32Count != 0) localDeclCount++;
+	if(function.localI64Count != 0) localDeclCount++;
+	if(function.localF32Count != 0) localDeclCount++;
+	if(function.localV128Count != 0) localDeclCount++;
+
+	FunctionCode body;
+	body.push_back(static_cast<uint8>(localDeclCount));
+	const auto pushLocal =
+	    [&body](uint32 count, uint8 type) {
+		    if(count == 0) return;
+		    body.push_back(static_cast<uint8>(count));
+		    body.push_back(type);
+	    };
+	pushLocal(function.localI32Count, Wasm::TYPE_I32);
+	pushLocal(function.localI64Count, Wasm::TYPE_I64);
+	pushLocal(function.localF32Count, Wasm::TYPE_F32);
+	pushLocal(function.localV128Count, Wasm::TYPE_V128);
+	body.insert(body.end(), function.code.begin(), function.code.end());
+	return body;
