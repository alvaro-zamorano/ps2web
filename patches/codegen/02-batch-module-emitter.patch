+// Walk the sections of a module emitted by WriteModule and pull out its single function body.
+// The prefix (type/import/function/export) is identical across all our modules, but we parse
+// properly instead of assuming a fixed offset.
+bool CWasmModuleBuilder::ExtractSingleFunctionBody(const uint8* moduleBytes, uint32 size, FunctionCode& outBody)
+{
+	const auto readULeb =
+	    [&](uint32& pos, uint32& outValue) -> bool {
+		    uint32 result = 0, shift = 0;
+		    while(pos < size)
+		    {
+			    uint8 byte = moduleBytes[pos++];
+			    result |= static_cast<uint32>(byte & 0x7F) << shift;
+			    if((byte & 0x80) == 0)
+			    {
+				    outValue = result;
+				    return true;
+			    }
+			    shift += 7;
+			    if(shift > 28) return false;
+		    }
+		    return false;
+	    };
+
+	if(size < 8) return false;
+	uint32 pos = 8; //magic + version
+	while(pos < size)
+	{
+		uint8 sectionId = moduleBytes[pos++];
+		uint32 sectionSize = 0;
+		if(!readULeb(pos, sectionSize)) return false;
+		if(pos + sectionSize > size) return false;
+		if(sectionId == Wasm::SECTION_ID_CODE)
+		{
+			uint32 codePos = pos;
+			uint32 functionCount = 0;
+			if(!readULeb(codePos, functionCount)) return false;
+			if(functionCount != 1) return false; //only single-function modules can be lifted
+			uint32 bodySize = 0;
+			if(!readULeb(codePos, bodySize)) return false;
+			if(codePos + bodySize > size) return false;
+			outBody.assign(moduleBytes + codePos, moduleBytes + codePos + bodySize);
+			return true;
+		}
+		pos += sectionSize;
+	}
+	return false;
+}
