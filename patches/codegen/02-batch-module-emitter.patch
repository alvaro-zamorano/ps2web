+// PS2WEB(JIT-04): see header. Built once from the fully-populated extern registry.
+const std::vector<std::string>& CWasmFunctionRegistry::GetCanonicalSignatures()
+{
+	//Function-local static: C++11 guarantees thread-safe one-time init. Blocks compile on
+	//several threads (EE/VU), so a lazily-built shared vector would be a data race.
+	//Safe because every extern is registered in CPs2VmJs::CreateVM, before any block compiles.
+	static const std::vector<std::string> canonical = []() {
+		std::set<std::string> distinct;
+		for(const auto& fctPair : m_functions)
+		{
+			distinct.insert(fctPair.second.signature);
+		}
+		std::vector<std::string> result;
+		//"vi" is the block's own signature and MUST be canonical index 0
+		//(the Function section emits signature index 0 for every block).
+		result.push_back("vi");
+		distinct.erase("vi");
+		for(const auto& signature : distinct) //std::set => deterministic order
+		{
+			result.push_back(signature);
+		}
+		return result;
+	}();
+	return canonical;
+}
